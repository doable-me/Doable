ild(el))</script><script src="/_next/static/chunks/polyfills-42372ed130431b0a.js" noModule=""></script></head><body class="__variable_f367f3 font-sans antialiased" style="font-family:var(--font-inter), system-ui, sans-serif"><div hidden=""><!--$--><!--/$--></div><!--$--><div class="min-h-screen bg-[#0a0a0a] text-gray-200"><nav class="sticky top-0 z-50 border-b border-gray-800/50 bg-[#0a0a0a]/80 backdrop-blur"><div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4 sm:px-6 lg:px-8"><a class="flex items-center gap-2" href="/"><div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-500 to-brand-300"><span class="text-sm font-bold text-white self-end mb-1">D</span><span class="h-2 w-2 rounded-full bg-violet-700 self-end mb-2 ml-0.5 shrink-0"></span></div><span class="text-lg font-semibold tracking-tight text-white">Doable</span></a><a class="flex items-center gap-1 text-sm text-gray-400 transition-colors hover:text-white" href="/"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left h-4 w-4"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>Back to home</a></div></nav><div class="border-b border-gray-800/50"><div class="mx-auto flex max-w-5xl gap-6 overflow-x-auto px-4 py-3 text-sm sm:px-6 lg:px-8"><a class="whitespace-nowrap text-gray-400 transition-colors hover:text-white" href="/terms">Terms of Service</a><a class="whitespace-nowrap text-gray-400 transition-colors hover:text-white" href="/privacy">Privacy Policy</a><a class="whitespace-nowrap text-gray-400 transition-colors hover:text-white" href="/cookies">Cookie Policy</a><a class="whitespace-nowrap text-gray-400 transition-colors hover:text-white" href="/acceptable-use">Acceptable Use</a><a class="whitespace-nowrap text-gray-400 transition-colors hover:text-white" href="/dmca">DMCA</a><a class="whitespace-nowrap text-gray-400 transition-colors hover:text-white" href="/contact">Contact</a></div></div><main class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8"><article class="legal-article"><h1>Acceptable Use Policy</h1><p class="text-sm text-gray-500"><strong>Last updated:</strong> April 27, 2026</p><p>This Acceptable Use Policy (“AUP”) describes activities that are not permitted on Doable, operated by<!-- --> <strong>Doable Works LLC</strong>. It supplements our<!-- --> <a href="/terms">Terms of Service</a>. Violations may result in suspension or termination of your account without refund and, where appropriate, referral to law enforcement.</p><h2>Prohibited content and behavior</h2><p>You may not use Doable to create, deploy, host, or distribute:</p><ul><li><strong>Illegal content</strong> — anything that violates applicable law in any jurisdiction where the content is accessed</li><li><strong>Malware</strong> — viruses, worms, trojans, ransomware, spyware, keyloggers, cryptojackers, or any code designed to harm or gain unauthorized access to systems</li><li><strong>Phishing or fraud</strong> — pages designed to impersonate other services, harvest credentials, or deceive users into transferring assets</li><li><strong>Child sexual abuse material (CSAM)</strong> — absolutely prohibited; reported to NCMEC and law enforcement</li><li><strong>Non-consensual intimate imagery</strong> or content that sexualizes minors in any form</li><li><strong>Targeted harassment</strong> — content directed at individuals with the intent to threaten, intimidate, dox, or stalk</li><li><strong>Hate speech and incitement</strong> — content promoting violence against people based on protected characteristics</li><li><strong>Terrorism and violent extremism</strong> — recruitment, glorification, or operational planning</li><li><strong>Counterfeit goods, controlled substances</strong>, or unlicensed financial services</li><li><strong>Spam</strong> — unsolicited bulk messaging, link farming, or SEO manipulation networks</li><li><strong>IP infringement</strong> — pirated software, media, or materials that infringe copyrights, trademarks, or patents</li></ul><h2>Prohibited technical activities</h2><ul><li>Scanning, probing, or testing the vulnerability of the Service or any system without express written permission</li><li>Circumventing or attempting to circumvent rate limits, quotas, billing, authentication, or other access controls</li><li>Reselling or proxying AI inference, credits, or compute capacity without our written agreement</li><li>Automated mass account creation, credential stuffing, or scraping the Service</li><li>Using the Service to mine cryptocurrency or perform unrelated compute workloads</li><li>Distributing private API keys, internal tokens, or credentials belonging to Doable Works LLC or other users</li><li>Interfering with the integrity, performance, or availability of the Service or other users’ experience</li></ul><h2>Responsible AI use</h2><ul><li>Do not generate Output designed to deceive in ways that cause harm (e.g., generating fake legal documents, impersonating real people, or producing political disinformation)</li><li>Do not use the Service to generate content that defames identifiable people</li><li>Always review and test AI-generated code before deploying to production. <em>You</em> are responsible for code you ship.</li><li>Do not submit private personal data of others to AI prompts without a lawful basis</li></ul><h2>Reporting violations</h2><p>If you become aware of a violation of this AUP, please report it to<!-- --> <a href="/cdn-cgi/l/email-protection#ec8d8e999f89ac88838d8e8089c28189"><span class="__cf_email__" data-cfemail="65040710160025010a040709004b0800">[email&#160;protected]</span></a>. For copyright complaints, see our <a href="/dmca">DMCA Policy</a>. For security vulnerabilities, see <a href="/cdn-cgi/l/email-protection#a1d2c4c2d4d3c8d5d8e1c5cec0c3cdc48fccc4"><span class="__cf_email__" data-cfemail="1467717761667d606d54707b757678713a7971">[email&#160;protected]</span></a>.</p><h2>Enforcement</h2><p>We may, at our sole discretion, investigate suspected violations, remove content, suspend or terminate accounts, and cooperate with law enforcement. We will, where reasonable and lawful, give you an opportunity to address the issue before taking action, except in cases of severe harm or legal risk.</p><h2>Changes</h2><p>We may update this AUP from time to time. The current version is always posted at this URL.</p><!--$--><!--/$--></article></main><footer class="border-t border-gray-800/50"><div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8"><p class="text-xs text-gray-600">© <!-- -->2026<!-- --> Doable Works LLC. All rights reserved. Doable is a registered service of Doable Works LLC.</p></div></footer></div><!--/$--><script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script src="/_next/static/chunks/webpack-392064f454473ca7.js" async=""></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,"1:\"$Sreact.fragment\"\n2:I[82991,[\"7177\",\"static/chunks/app/layout-43c097e5cd8aedfd.js\"],\"TracingInit\"]\n3:I[48984,[],\"\"]\n4:I[16303,[\"8039\",\"static/chunks/app/error-1624ed23f152bc29.js\"],\"default\"]\n5:I[8270,[],\"\"]\n6:I[43849,[\"3849\",\"static/chunks/3849-c0424a57e6cb463a.js\",\"4878\",\"static/chunks/app/(legal)/layout-ccaaeb65f7084f7e.js\"],\"\"]\n7:I[85112,[],\"OutletBoundary\"]\na:I[98400,[],\"AsyncMetadataOutlet\"]\nc:I[85112,[],\"ViewportBoundary\"]\ne:I[85112,[],\"MetadataBoundary\"]\n10:I[58567,[],\"\"]\n:HL[\"/_next/static/media/e4af272ccee01ff0-s.p.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n:HL[\"/_next/static/css/081a0afca5a9bd20.css\",\"style\"]\n:HL[\"/_next/static/css/a1e78c37c87b881d.css\",\"style\"]\n"])</script><script>self.__next_f.push([1,"0:{\"P\":null,\"b\":\"OxWO_cB8QV8W8wROqlqjx\",\"p\":\"\",\"c\":[\"\",\"a