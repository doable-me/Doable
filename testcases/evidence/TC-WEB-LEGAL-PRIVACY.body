i\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Communications:\"}],\" support requests, feedback, and any other messages you send us\"]}]]}],[\"$\",\"h3\",null,{\"children\":\"Information collected automatically\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Usage data:\"}],\" pages visited, features used, AI prompts and responses, errors encountered, timestamps\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Device and connection:\"}],\" IP address, browser type, operating system, device identifiers\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Cookies and similar:\"}],\" see our\",\" \",[\"$\",\"a\",null,{\"href\":\"/cookies\",\"children\":\"Cookie Policy\"}]]}]]}],[\"$\",\"h3\",null,{\"children\":\"Information from third parties\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"OAuth providers (GitHub, Google) when you connect those accounts\"}],[\"$\",\"li\",null,{\"children\":\"Stripe for billing and subscription status\"}],[\"$\",\"li\",null,{\"children\":\"Integration partners that you authorize Doable to connect with on your behalf\"}]]}],[\"$\",\"h2\",null,{\"children\":\"2. How We Use Your Information\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"To provide, operate, and maintain the Service\"}],[\"$\",\"li\",null,{\"children\":\"To process AI requests by sending prompts and context to AI providers (Anthropic, OpenAI, GitHub Copilot) you have selected\"}],[\"$\",\"li\",null,{\"children\":\"To process payments and manage subscriptions\"}],[\"$\",\"li\",null,{\"children\":\"To communicate with you about the Service, billing, and support\"}],[\"$\",\"li\",null,{\"children\":\"To detect, investigate, and prevent fraud, abuse, and security incidents\"}],[\"$\",\"li\",null,{\"children\":\"To improve the Service and develop new features\"}],[\"$\",\"li\",null,{\"children\":\"To comply with legal obligations\"}]]}],[\"$\",\"h2\",null,{\"children\":\"3. AI Providers and Your Prompts\"}],[\"$\",\"p\",null,{\"children\":\"When you use AI features, your prompts and project context are sent to the AI provider you have configured (Anthropic, OpenAI, or GitHub Copilot). Each provider has its own data-handling practices:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Anthropic:\"}],\" \",[\"$\",\"a\",null,{\"href\":\"https://www.anthropic.com/privacy\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"children\":\"Privacy Policy\"}]]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"OpenAI:\"}],\" \",[\"$\",\"a\",null,{\"href\":\"https://openai.com/policies/privacy-policy\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"children\":\"Privacy Policy\"}]]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"GitHub Copilot:\"}],\" \",[\"$\",\"a\",null,{\"href\":\"https://docs.github.com/en/site-policy/privacy-policies/github-privacy-statement\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"children\":\"Privacy Statement\"}]]}]]}],[\"$\",\"p\",null,{\"children\":\"We do not use your prompts or generated code to train our own AI models.\"}],[\"$\",\"h2\",null,{\"children\":\"4. Information Sharing\"}],[\"$\",\"p\",null,{\"children\":\"We do not sell your personal information. We share information only:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"With service providers\"}],\" who help us operate the Service (hosting, payment processing, analytics, error monitoring, email delivery), under contractual confidentiality and security obligations\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"With AI providers\"}],\" as necessary to fulfil your requests\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"With integration partners\"}],\" you explicitly authorize\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"For legal reasons\"}],\" when required by law, subpoena, or to protect rights, property, or safety\"]}],[\"$\",\"li\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"In a business transfer\"}],\" if Doable Works LLC is acquired, merged, or sells assets, in which case we will provide notice\"]}]]}],[\"$\",\"h2\",null,{\"children\":\"5. Data Retention\"}],[\"$\",\"p\",null,{\"children\":\"We retain your personal information for as long as your account is active and as needed to provide the Service. After you delete your account, we will delete or anonymize your data within 90 days, except where retention is required by law (e.g., billing records) or for legitimate security purposes (e.g., fraud prevention logs).\"}],[\"$\",\"h2\",null,{\"children\":\"6. Security\"}],[\"$\",\"p\",null,{\"children\":\"We use industry-standard security measures, including:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Argon2id password hashing\"}],[\"$\",\"li\",null,{\"children\":\"JWT-based authentication with short-lived access tokens\"}],[\"$\",\"li\",null,{\"children\":\"TLS encryption for data in transit\"}],[\"$\",\"li\",null,{\"children\":\"Encryption at rest for sensitive credentials (AES-GCM)\"}],[\"$\",\"li\",null,{\"children\":\"Network isolation with services bound to localhost only\"}],[\"$\",\"li\",null,{\"children\":\"Rate limiting on authentication endpoints\"}],[\"$\",\"li\",null,{\"children\":\"Regular security audits\"}]]}],[\"$\",\"p\",null,{\"children\":[\"No system is 100% secure. If you suspect a security issue, please contact\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:security@doable.me\",\"children\":\"security@doable.me\"}],\".\"]}],[\"$\",\"h2\",null,{\"children\":\"7. Your Rights\"}],[\"$\",\"p\",null,{\"children\":\"Depending on your jurisdiction, you may have the right to:\"}],[\"$\",\"ul\",null,{\"children\":[[\"$\",\"li\",null,{\"children\":\"Access the personal information we hold about you\"}],[\"$\",\"li\",null,{\"children\":\"Correct inaccurate information\"}],[\"$\",\"li\",null,{\"children\":\"Delete your information (right to be forgotten)\"}],[\"$\",\"li\",null,{\"children\":\"Export your information in a portable format\"}],[\"$\",\"li\",null,{\"children\":\"Object to or restrict certain processing\"}],[\"$\",\"li\",null,{\"children\":\"Withdraw consent\"}],[\"$\",\"li\",null,{\"children\":\"Lodge a complaint with a supervisory authority\"}]]}],[\"$\",\"p\",null,{\"children\":[\"To exercise these rights, email\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:privacy@doable.me\",\"children\":\"privacy@doable.me\"}],\". We will respond within 30 days.\"]}],[\"$\",\"h2\",null,{\"children\":\"8. International Transfers\"}],[\"$\",\"p\",null,{\"children\":\"Doable Works LLC is based in the United States. If you access the Service from outside the U.S., your information may be transferred to, stored, and processed in the U.S. or other countries where our service providers operate. Where required, we use Standard Contractual Clauses or other lawful transfer mechanisms.\"}],[\"$\",\"h2\",null,{\"children\":\"9. Children’s Privacy\"}],[\"$\",\"p\",null,{\"children\":[\"The Service is not intended for children under 13. We do not knowingly collect personal information from children under 13. If you believe a child has provided us with personal information, please contact\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:privacy@doable.me\",\"children\":\"privacy@doable.me\"}],\" and we will delete it.\"]}],[\"$\",\"h2\",null,{\"children\":\"10. California Privacy Rights (CCPA/CPRA)\"}],[\"$\",\"p\",null,{\"children\":[\"California residents have additional rights under the California Consumer Privacy Act, including the right to know, delete, correct, and opt out of “sales” or “sharing” of personal information. We do not sell personal information. To exercise California rights, email\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:privacy@doable.me\",\"children\":\"privacy@doable.me\"}],\".\"]}],[\"$\",\"h2\",null,{\"children\":\"11. European Economic Area Rights (GDPR)\"}],[\"$\",\"p\",null,{\"children\":\"If you are in the EEA, UK, or Switzerland, our legal bases for processing your information are: (a) performance of our contract with you, (b) your consent (which you may withdraw at any time), (c) our legitimate interests in operating and improving the Service, and (d) compliance with legal obligations.\"}],[\"$\",\"h2\",null,{\"children\":\"12. Changes to This Policy\"}],[\"$\",\"p\",null,{\"children\":\"We may update this Privacy Policy from time to time. We will post the updated version on this page and update the “Last updated” date. For material changes, we will notify you by email or through the Service.\"}],[\"$\",\"h2\",null,{\"children\":\"13. Contact\"}],[\"$\",\"p\",null,{\"children\":[\"Questions or requests about this Privacy Policy? Contact our privacy team at\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:privacy@doable.me\",\"children\":\"privacy@doable.me\"}],\".\"]}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Doable Works LLC\"}],[\"$\",\"br\",null,{}],\"Email: \",[\"$\",\"a\",null,{\"href\":\"mailto:privacy@doable.me\",\"children\":\"privacy@doable.me\"}]]}]],null,[\"$\",\"$L7\",null,{\"children\":[\"$L8\",\"$L9\",[\"$\",\"$La\",null,{\"promise\":\"$@b\"}]]}]]}],{},null,false]},null,false]},null,false]},[[\"$\",\"div\",\"l\",{\"className\":\"flex min-h-screen items-center justify-center bg-background\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex flex-col items-center gap-3\",\"children\":[[\"$\",\"div\",null,{\"className\":\"h-8 w-8 animate-spin rounded-full border-2 border-brand-500 border-t-transparent\"}],[\"$\",\"p\",null,{\"className\":\"text-sm text-zinc-500\",\"children\":\"Loading...\"}]]}]}],[],[]],false],[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\