t-sm font-medium text-black hover:bg-gray-200" href="/signup">Get started</a></div></div></nav><section class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center overflow-hidden px-4"><div class="pointer-events-none absolute inset-0"><div class="absolute inset-0 bg-gradient-to-b from-brand-950 via-[#0a0a0a] to-transparent opacity-80"></div><div class="absolute left-1/2 top-1/3 h-[600px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-600/15 blur-[120px]"></div><div class="absolute bottom-0 left-0 right-0 h-[50vh]"><div class="absolute inset-0 bg-gradient-to-t from-brand-400/20 via-brand-300/10 to-transparent"></div><div class="absolute bottom-0 left-1/4 h-[300px] w-[400px] rounded-full bg-brand-500/15 blur-[100px]"></div><div class="absolute bottom-0 right-1/4 h-[300px] w-[400px] rounded-full bg-brand-400/15 blur-[100px]"></div></div></div><div class="relative z-10 mx-auto w-full max-w-3xl text-center"><h1 class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">Dream it. Do it. Done.</h1><p class="mb-12 text-base text-gray-400 sm:text-lg">Say it. Doable does it.</p><form class="mx-auto w-full max-w-2xl"><div class="rounded-2xl border border-gray-800 bg-[#1a1a1a] p-3 shadow-2xl shadow-black/50 transition-colors focus-within:border-gray-600"><textarea placeholder="What do you want Doable to do?" rows="3" class="w-full resize-none bg-transparent px-2 pt-1 text-sm text-white placeholder:text-gray-500 focus:outline-none sm:text-base"></textarea><div class="flex items-center justify-between pt-1"><div class="flex items-center gap-1"><button type="button" class="rounded-lg p-2 text-gray-500 transition-colors hover:bg-gray-800 hover:text-gray-300" title="Attach file"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus h-5 w-5"><path d="M5 12h14"></path>