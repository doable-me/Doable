{
  "name": "@doable/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@doable/db": "workspace:*",
    "@doable/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "argon2": "^0.41.1",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
