{
  "name": "@doable/ws",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node --env-file=../../.env dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@doable/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "ws": "^8.18.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
