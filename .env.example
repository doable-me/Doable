# ==============================================================================
# Doable — Local development environment (pnpm / bare metal)
# ==============================================================================
# No root/sudo required. Copy and fill secrets:
#   cp .env.example .env
#   # then: start Postgres (Docker, non-root docker group is fine), migrate, run
#
# Quick path:
#   ./scripts/dev-local.sh
#
# Or manually:
#   docker compose -f deployment/docker/docker-compose.dev.yml \
#     --env-file deployment/docker/.env up postgres -d
#   pnpm install && pnpm db:migrate && pnpm dev
#
# Services (defaults):
#   Web  http://127.0.0.1:3000
#   API  http://127.0.0.1:4000
#   WS   ws://127.0.0.1:4001
# ==============================================================================

# ─── Database (REQUIRED) ───────────────────────────────────
# Match POSTGRES_* in deployment/docker/.env when using docker-compose.dev.yml
DATABASE_URL=postgres://doable:doable-local-dev@127.0.0.1:5432/doable

# ─── Crypto (REQUIRED) ─────────────────────────────────────
# Master KEK: 32 raw bytes, base64-encoded (44 chars). Do not rotate after first use.
# Generate: openssl rand -base64 32
DOABLE_KEK=CHANGE_ME_run_openssl_rand_base64_32

# These three auto-generate into .doable-data/dev-secrets.json if omitted in
# non-production. Set them explicitly for stable multi-service restarts:
# JWT_SECRET=
# ENCRYPTION_KEY=
# INTERNAL_SECRET=

# ─── Local hardening OFF (no bubblewrap / AppArmor / UID drop) ─
# Production VPS uses full sandboxing via deployment/server-setup.sh.
# For laptop/dev without root, leave these off.
DOABLE_HARDENING=off
DOABLE_HARDENING_LEVEL=off
DOABLE_DEV_UID_DISABLED=1

# ─── Runtime ───────────────────────────────────────────────
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4000
WS_HOST=127.0.0.1
WS_PORT=4001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Per-app PGlite DB + in-app AI proxy (defaults ON)
DOABLE_APP_DB_ENABLED=1
DOABLE_APP_AI_ENABLED=1

# ─── AI (optional — also configurable in /setup wizard) ───
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# ─── OAuth (optional — see .env.integrations.example) ─────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
