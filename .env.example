# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgres://doable:doable_secret@localhost:5432/doable
DATABASE_POOL_SIZE=20

# ─── Auth / JWT ─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_ISSUER=doable
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ─── API Server ─────────────────────────────────────────────
API_PORT=4000
API_HOST=127.0.0.1
CORS_ORIGINS=http://localhost:3000

# ─── WebSocket Server ──────────────────────────────────────
WS_PORT=4001
WS_HOST=127.0.0.1

# ─── Internal Comms (API <-> WS) ──────────────────────────
INTERNAL_SECRET=change-me-to-a-random-string
WS_INTERNAL_URL=http://localhost:4001
API_URL=http://localhost:4000

# ─── Next.js Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── OAuth ──────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4000/auth/github/callback
GITHUB_COPILOT_REDIRECT_URI=http://localhost:4000/auth/github/copilot/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ─── AI / Copilot SDK ─────────────────────────────────────
COPILOT_DEFAULT_MODEL=
COPILOT_CLI_PATH=
COPILOT_CLI_URL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Storage (S3-compatible) ───────────────────────────────
S3_BUCKET=doable-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_YEARLY_PRICE_ID=

# ─── Publish / Hosting ────────────────────────────────────
PROJECTS_ROOT=./services/api/projects
SITES_DIR=./sites
DOABLE_DOMAIN=localhost

# ─── Custom Domains (Cloudflare for SaaS) ────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CUSTOM_DOMAIN_CNAME_TARGET=custom.doable.me
CADDYFILE_PATH=/etc/caddy/Caddyfile

# ─── Environment ───────────────────────────────────────────
NODE_ENV=development
