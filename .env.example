# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgres://doable:doable_secret@localhost:5432/doable
DATABASE_POOL_SIZE=20

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / JWT ─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_ISSUER=doable
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ─── API Server ─────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# ─── WebSocket Server ──────────────────────────────────────
WS_PORT=4001
WS_HOST=0.0.0.0

# ─── Next.js Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── OAuth ──────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI / Copilot SDK ─────────────────────────────────────
# The Copilot SDK is the core AI engine. Auth options:
#   1. GitHub Copilot subscription (auto-detected if `copilot` CLI is on PATH)
#   2. BYOK: set one of the API keys below
COPILOT_DEFAULT_MODEL=
COPILOT_CLI_PATH=
COPILOT_CLI_URL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Storage (S3-compatible) ───────────────────────────────
S3_BUCKET=doable-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ─── Environment ───────────────────────────────────────────
NODE_ENV=development
